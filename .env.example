# Copy this file to .env.local and fill in your provider key.
# .env.local is git-ignored — never commit real keys.

# --- Option A: OpenAI via Vocareum gateway (voc- key) ---
# Your Vocareum lab's AI panel shows both the key and the base URL.
OPENAI_API_KEY=voc-your-vocareum-key-here
OPENAI_BASE_URL=https://openai.vocareum.com/v1

# --- Option B: standard OpenAI key (sk-...) ---
# OPENAI_API_KEY=sk-your-openai-key-here
# (omit OPENAI_BASE_URL — it defaults to https://api.openai.com/v1)

# --- Option C: Anthropic (Claude) ---
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: override the model. Must match a model your key can access.
# OpenAI examples:    gpt-4o-mini (default), gpt-4o
# Anthropic examples: claude-sonnet-4-6 (default), claude-haiku-4-5
# MODEL=gpt-4o-mini
